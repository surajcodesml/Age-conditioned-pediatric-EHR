{
  "name": "Pediatric Asthma (early-onset, age-varying)",
  "remarks": [
    "Childhood-predominant asthma onset, independent of obesity, to provide an",
    "early-developmental-band downstream task. Onset is concentrated in infancy /",
    "early childhood / school age with a small adolescent tail, so the onset-age",
    "distribution is non-flat and front-loaded relative to the obesity tasks.",
    "Onset occurs after birth (>=1 prior well-child event), satisfying the",
    "first_occurrence_idx > 0 requirement of build_disease_cohort."
  ],
  "states": {
    "Initial": {
      "type": "Initial",
      "direct_transition": "Asthma_Onset_Band"
    },
    "Asthma_Onset_Band": {
      "type": "Simple",
      "distributed_transition": [
        { "distribution": 0.05, "transition": "Track_Infant" },
        { "distribution": 0.07, "transition": "Track_Early_Childhood" },
        { "distribution": 0.05, "transition": "Track_School_Age" },
        { "distribution": 0.02, "transition": "Track_Adolescent" },
        { "distribution": 0.81, "transition": "Never_Asthma" }
      ]
    },
    "Track_Infant": {
      "type": "Delay",
      "range": { "low": 0.5, "high": 1, "unit": "years" },
      "direct_transition": "Onset_Asthma"
    },
    "Track_Early_Childhood": {
      "type": "Delay",
      "range": { "low": 1, "high": 5, "unit": "years" },
      "direct_transition": "Onset_Asthma"
    },
    "Track_School_Age": {
      "type": "Delay",
      "range": { "low": 6, "high": 11, "unit": "years" },
      "direct_transition": "Onset_Asthma"
    },
    "Track_Adolescent": {
      "type": "Delay",
      "range": { "low": 12, "high": 17, "unit": "years" },
      "direct_transition": "Onset_Asthma"
    },
    "Onset_Asthma": {
      "type": "ConditionOnset",
      "assign_to_attribute": "peds_asthma_condition",
      "target_encounter": "Asthma_Encounter",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "195967001",
          "display": "Asthma (disorder)"
        }
      ],
      "direct_transition": "Asthma_Encounter"
    },
    "Asthma_Encounter": {
      "type": "Encounter",
      "encounter_class": "ambulatory",
      "reason": "peds_asthma_condition",
      "codes": [
        {
          "system": "SNOMED-CT",
          "code": "162673000",
          "display": "General examination of patient (procedure)"
        }
      ],
      "direct_transition": "Albuterol_Medication"
    },
    "Albuterol_Medication": {
      "type": "MedicationOrder",
      "codes": [
        {
          "system": "RxNorm",
          "code": "745679",
          "display": "Albuterol 0.09 MG/ACTUAT Metered Dose Inhaler"
        }
      ],
      "direct_transition": "End_Asthma_Encounter"
    },
    "End_Asthma_Encounter": {
      "type": "EncounterEnd",
      "direct_transition": "Asthma_Terminal"
    },
    "Asthma_Terminal": {
      "type": "Terminal"
    },
    "Never_Asthma": {
      "type": "Terminal"
    }
  },
  "gmf_version": 2
}
